{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/static/:path*",
      "destination": "/static/:path*"
    },
    {
      "source": "/",
      "destination": "/static/index.html"
    },
    {
      "source": "/:path((?!static).+)",
      "destination": "/static/index.html"
    }
  ]
}

