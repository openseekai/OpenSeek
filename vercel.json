{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/static/:path*",
      "destination": "/backend/static/:path*"
    },
    {
      "source": "/",
      "destination": "/backend/static/index.html"
    },
    {
      "source": "/:path((?!backend|static).+)",
      "destination": "/backend/static/index.html"
    }
  ]
}

